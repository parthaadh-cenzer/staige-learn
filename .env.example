# ============================================================================
#  STAIGE Learning Platform — environment
#
#  Copy to `.env.local` for local development. `.env*` is gitignored: never
#  commit a filled-in copy of this file. In production these live in Vercel →
#  Project → Settings → Environment Variables, and nowhere else.
#
#  THE VITE_ RULE, because getting it wrong leaks a key:
#    Vite inlines every VITE_-prefixed variable into the JavaScript it ships to
#    the browser. Anything prefixed VITE_ is PUBLIC — treat it as printed on the
#    homepage. Everything below without the prefix is server-only and is read
#    exclusively by the functions in api/.
#    => Never prefix STRIPE_SECRET_KEY or SUPABASE_SERVICE_ROLE_KEY with VITE_.
# ============================================================================

# ── Public: shipped to the browser ──────────────────────────────────────────
# The anon key is meant to be public. Row Level Security decides what it can
# actually read — see supabase/migrations/0001_staige_learn.sql.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=

# Public support address shown on the Contact page and in the footer. Safe to
# ship. Must be VITE_-prefixed to reach the browser bundle; while unset, those
# surfaces say "not published yet" instead of inventing an address.
VITE_CONTACT_EMAIL=hello@staige.world

# ── Server-only: Supabase ───────────────────────────────────────────────────
# Same values as above, under the names the serverless functions read.
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=

# Bypasses Row Level Security completely. The webhook uses it to write
# entitlements no user is allowed to write. If this leaks, every learner's data
# is readable and writable by anyone — rotate it immediately in Supabase →
# Settings → API. Never send it to the browser, never paste it into a client
# file, never commit it.
SUPABASE_SERVICE_ROLE_KEY=

# ── Server-only: Stripe ─────────────────────────────────────────────────────
# sk_test_… while testing, sk_live_… in production.
STRIPE_SECRET_KEY=

# From Stripe → Developers → Webhooks → your endpoint → Signing secret (whsec_…).
# Test mode and live mode have DIFFERENT signing secrets.
STRIPE_WEBHOOK_SECRET=

# ── Server-only: the approved price list ────────────────────────────────────
# The only prices the platform will ever charge or honour. /api/checkout picks
# one of these by product key; the webhook refuses to grant access for a Price
# that isn't in this list. Values are Stripe Price IDs (price_…), not amounts.
# Regular = $10, Intro = $5 — see shared/catalog.mjs.
STRIPE_PRICE_SIDE_HUSTLE_REGULAR=
STRIPE_PRICE_SIDE_HUSTLE_INTRO=
STRIPE_PRICE_MARKETING_REGULAR=
STRIPE_PRICE_MARKETING_INTRO=
STRIPE_PRICE_JOB_HUNTER_REGULAR=
STRIPE_PRICE_JOB_HUNTER_INTRO=

# ── Server-only: the app's own address ──────────────────────────────────────
# Every Stripe redirect is built from this, never from the incoming request, so
# a forged Host header can't turn checkout into an open redirect.
# Locally: http://localhost:5180
APP_URL=https://learn.staige.world

# ── Admin ────────────────────────────────────────────────────────────────────
# There is NO admin env var. Admin authority lives in the `public.admins` table
# (migration 0003), written only by the service-role key. Grant the owner via
# supabase/scripts/grant_owner_access.sql after they sign up — never via a flag
# here, so admin can't be conferred by editing config or client state.
